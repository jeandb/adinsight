# Production environment variables
# Copy this file to /etc/adinsight.env on the server and fill in the values.
# Then load before deploying: set -a; source /etc/adinsight.env; set +a
# Or export each variable individually before running docker stack deploy.

DATABASE_URL=postgresql://user:password@host:5432/adinsight
REDIS_URL=redis://host:6379

JWT_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_KEY=

BCRYPT_ROUNDS=12

FRONTEND_URL=https://adinsightapp.jaquemendes.com

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AdInsight <admin@example.com>
